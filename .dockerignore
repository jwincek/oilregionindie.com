# Secrets — never bake into the image
.env
.env.*

# Test code — CI owns testing; the production artifact doesn't run it
apps/*/tests

# Local state and artifacts
db.sqlite3
media/
staticfiles/
venv/
venv3-13/
__pycache__/
*.pyc
.coverage
htmlcov/

# Not needed in the image
.git/
.gitignore
.claude/
.dockerignore
docker-compose*.yml
Dockerfile
*.md
